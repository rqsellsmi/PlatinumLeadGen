# =============================================================================
# RE/MAX Platinum Lead Platform — Environment Variables (Spec Section 13)
# Copy this file to `.env` and fill in every value. The app validates all
# required vars at startup (lib/env.ts) and throws if any are missing.
# Stack: Next.js · Neon PostgreSQL (sole data store) · MS Graph email.
# No Upstash. No Redis. No Resend.
# =============================================================================

# --- Database (Neon) ---------------------------------------------------------
# Neon PostgreSQL connection string (Neon console → Connection Details).
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# --- NextAuth (admin + agent session signing) --------------------------------
# Random 32+ char string. Generate: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="https://remax-platinumonline.com"

# Admin credentials. Password stored ONLY as a bcrypt hash (cost 12).
# Generate the hash with: npm run hash-password -- 'yourPlaintextPassword'
ADMIN_USERNAME="owner"
ADMIN_PASSWORD_HASH="$2a$12$replace.with.a.real.bcrypt.hash.value.................."

# --- Email (Microsoft 365 via Microsoft Graph, Section 6) --------------------
# Azure App Registration with Graph application permissions Mail.Send + Mail.ReadWrite
# (admin consent granted). Reuse the old system's app credentials if available.
MS_GRAPH_CLIENT_ID="your-app-client-id"
MS_GRAPH_CLIENT_SECRET="your-app-client-secret"
MS_GRAPH_TENANT_ID="your-tenant-id"
# The Microsoft 365 mailbox to send from (a real, monitored inbox — not no-reply).
MS_GRAPH_FROM_EMAIL="leads@remaxplatinum.com"
# Where admin alerts, escalations, and the broker digest go (owner email).
MS_GRAPH_ADMIN_EMAIL="owner@remaxplatinum.com"

# --- Property Valuation ------------------------------------------------------
# Which AVM provider answers valuations at runtime: "rentcast" (default) or
# "attom". This is a RUNTIME flag — flip it in the Vercel dashboard to switch
# providers or roll back instantly, no code change or redeploy-from-branch.
# Both clients stay compiled in; ATTOM falls back to RentCast on error.
VALUATION_PROVIDER="rentcast"
RENTCAST_API_KEY="your-rentcast-api-key"
# Required only when VALUATION_PROVIDER=attom.
ATTOM_API_KEY="your-attom-api-key"
# ATTOM Sales Trend / Sales Comparables are SEPARATE products from the AVM
# bundle. Leave off until your ATTOM plan includes them; set to 1 to turn on
# the report's "Local market trends" section and ATTOM comps fallback.
# ATTOM_ENABLE_TRENDS="1"
# ATTOM_ENABLE_COMPS="1"

# --- Telnyx SMS (agent texting) — optional; email still sends without it -------
# API key from the Telnyx portal (Auth → API Keys). Enables agent lead texts.
# TELNYX_API_KEY="KEY..."
# Public key for verifying inbound webhook signatures (Telnyx portal → your
# Messaging Profile / public key). Required for the inbound webhook to accept events.
# TELNYX_PUBLIC_KEY="base64-ed25519-public-key"
# Optional: pin a Messaging Profile for outbound sends.
# TELNYX_MESSAGING_PROFILE_ID="MP..."
# Optional fallback "from" number (E.164) when an agent's office has no number set.
# TELNYX_DEFAULT_FROM="+15551234567"
#
# Per-office sending numbers live in the DB (offices.telnyx_number), not here.
# Carrier registration (10DLC brand+campaign OR toll-free verification) is
# REQUIRED before messages deliver reliably — see SETUP.md.

# --- Google Ads offline conversions (Data Manager API) — optional --------------
# Sends server-side conversions when a seller lead first reaches Nurturing
# (Valid Seller Lead), Signed, or Closed. The whole feature no-ops silently
# until the customer id AND service-account key below are both set. Set these in
# BOTH Vercel (the app enqueues + the cron route sends) and GitHub Actions is not
# needed here — the worker runs in the app; Actions only pings it via CRON_SECRET.
# See docs/superpowers/specs/2026-07-24-google-ads-lead-stage-tracking-design.md.
#
# Google Ads customer id (digits only, no dashes).
# GOOGLE_ADS_CUSTOMER_ID="1234567890"
# The three offline conversion action ids (Data Manager productDestinationId),
# created by your Google Ads admin (Goals → Conversions → offline actions).
# GOOGLE_ADS_ACTION_ID_VALID_SELLER_LEAD="..."
# GOOGLE_ADS_ACTION_ID_LISTING_SIGNED="..."
# GOOGLE_ADS_ACTION_ID_CLOSED="..."
# Service-account key JSON (raw JSON on one line, or base64-encoded to avoid
# newline issues). The account needs Google Ads access + the datamanager scope.
# GOOGLE_ADS_SA_KEY='{"client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","token_uri":"https://oauth2.googleapis.com/token"}'
# Consent value sent on every event (D1: constant; US/MI first-party ads).
# 'unspecified' (default) | 'granted' | 'denied'.
# GOOGLE_ADS_CONSENT="unspecified"
# Set to 1 during QA so Data Manager validates the payload WITHOUT recording it.
# GOOGLE_ADS_VALIDATE_ONLY="1"
# Optional: override the exportable lead types (default: valuation,seller_guide).
# GOOGLE_ADS_ELIGIBLE_LEAD_TYPES="valuation,seller_guide"

# --- Google Maps (Places autocomplete) ---------------------------------------
# Server-side key (not exposed to the client).
GOOGLE_MAPS_API_KEY="your-google-maps-server-key"
# Client-side key — MUST be restricted to remax-platinumonline.com in Google Cloud.
# Also powers the listing-page embedded map (Maps Embed API — free per load).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-browser-key"
# Listing-page "Neighborhood Highlights" (nearby restaurants/parks/etc. via Google
# Places Nearby Search, billed per call, cached per ~110m grid cell). On by default
# when GOOGLE_MAPS_API_KEY is set + the legacy Places API is enabled; set to 0 to disable.
# LISTING_AREA_POI="0"

# --- Analytics / tracking (Section 21) — optional; tracking no-ops if unset ---
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"
NEXT_PUBLIC_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_CLARITY_PROJECT_ID="xxxxxxxxxx"

# --- Site / secrets ----------------------------------------------------------
# Used in email links and canonical URLs.
SITE_URL="https://remax-platinumonline.com"
# Random string — authenticates Vercel Cron / GitHub Actions cron calls (x-cron-secret).
CRON_SECRET="change-me-to-a-long-random-string"
# Random string — authenticates on-demand ISR revalidation calls (x-revalidate-secret).
REVALIDATE_SECRET="change-me-to-a-long-random-string"

# --- Realcomp IDX feed (Section: IDX Integration Spec) -----------------------
# OAuth client credentials from the Realcomp "API Authorization" email. Keep the
# secret server-side only. All five are optional — IDX features (Similar Homes,
# Market Report, IDX-driven metrics) disable cleanly if unset, and the app logs a
# warning on startup rather than crashing.
REALCOMP_CLIENT_ID=""
REALCOMP_CLIENT_SECRET=""
# OData API base URL and OAuth token endpoint (per Realcomp support).
REALCOMP_BASE_URL="https://idxapi.realcomp.com/odata"
REALCOMP_AUTH_URL="https://auth.realcomp.com/Token"
# OAuth token audience — account-specific. Realcomp support: rcapi.realcomp.com
# (note the 'c' — NOT rapi.realcomp.com). Wrong audience => token endpoint 500s.
REALCOMP_AUDIENCE="rcapi.realcomp.com"
# Comma-separated list of ALL RE/MAX Platinum numeric Office Key IDs. A deal
# counts as "yours" when any of these appears as the listing, buyer, co-list, or
# co-buyer office. Parsed at runtime — add a new office here (Vercel + GitHub
# Actions secret), no code change needed. Example (replace with your real keys):
# REALCOMP_OFFICE_KEYS="630843964049,814805080452,814703158334,541626279814"
REALCOMP_OFFICE_KEYS=""
# Display-only office name (never used in a query filter).
REALCOMP_OFFICE_NAME="RE/MAX Platinum"

# --- Optional ----------------------------------------------------------------
# Vercel Blob storage for admin photo uploads (recent-sales tiles). Auto-added
# when you create a Blob store in the Vercel dashboard and connect the project.
# Uploads degrade gracefully (show a message) if this is unset.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
# Set to 1 to skip env validation (CI builds without secrets).
# SKIP_ENV_VALIDATION="1"
