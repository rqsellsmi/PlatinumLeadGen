# =============================================================================
# RE/MAX Platinum Lead Platform — Environment Variables (Section 12)
# Copy this file to `.env` and fill in every value. The app validates all
# required vars at startup (lib/env.ts) and throws if any are missing.
# =============================================================================

# --- Database (Neon) ---------------------------------------------------------
# Neon PostgreSQL connection string. Use the pooled or direct connection URL.
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# --- Cache & Rate Limiting (Upstash Redis) -----------------------------------
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# --- NextAuth (Admin auth) ---------------------------------------------------
# Random 32+ char string for session signing. Generate: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="https://remax-platinumonline.com"

# Admin credentials. Password is stored ONLY as a bcrypt hash (cost 12).
# Generate the hash with: npm run hash-password -- 'yourPlaintextPassword'
ADMIN_USERNAME="owner"
ADMIN_PASSWORD_HASH="$2a$12$replace.with.a.real.bcrypt.hash.value.................."

# --- Email (Resend) ----------------------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# Must be on a Resend-verified domain or emails will not send.
RESEND_FROM_EMAIL="leads@remaxplatinum.email"
RESEND_FROM_NAME="RE/MAX Platinum"
# Where admin alerts, escalations, and the broker digest are delivered.
RESEND_ADMIN_EMAIL="owner@remaxplatinum.email"

# --- Property Valuation (RentCast) -------------------------------------------
RENTCAST_API_KEY="your-rentcast-api-key"

# --- Google Maps (Places autocomplete) ---------------------------------------
# Server-side key.
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
# Client-exposed key (restrict by HTTP referrer in the Google Cloud console).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# --- Site / Cron -------------------------------------------------------------
# Used in email links and canonical URLs.
SITE_URL="https://remax-platinumonline.com"
# Random string — authenticates Vercel Cron job calls (sent as x-cron-secret).
CRON_SECRET="change-me-to-a-long-random-string"

# --- Optional ----------------------------------------------------------------
# Set to 1 to skip env validation (used only by CI builds without secrets).
# SKIP_ENV_VALIDATION="1"
