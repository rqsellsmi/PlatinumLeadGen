{
  "name": "remax-lead-platform",
  "version": "1.2.0",
  "private": true,
  "description": "RE/MAX Platinum unified lead generation & routing platform",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:setup": "drizzle-kit migrate && tsx scripts/seed.ts",
    "seed": "tsx scripts/seed.ts",
    "hash-password": "tsx scripts/hash-password.ts",
    "idx:sync": "tsx scripts/idx-initial-sync.ts",
    "idx:verify": "tsx scripts/idx-verify-metadata.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@vercel/blob": "^2.5.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.38.3",
    "next": "^14.2.33",
    "next-auth": "5.0.0-beta.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
